+++
+++@app.get("/health")
+++def health():
+++    return {"status": "ok", "module": "store-manager", "version": "v0.1.3"}
+++
+++
+++client = TestClient(app)
+++
+++_passed = 0
+++_failed = 0
+++_results = []
+++
+++
+++def check(name, cond, detail=""):
+++    global _passed, _failed
+++    ok = bool(cond)
