++                       f"家居产品【{name}】预计已用完，建议复购跟进。")
++    elif days_left <= 7:
++        create_warning(conn, customer_id, "home_product_low", "yellow", f"home_product:{pid}",
++                       f"家居产品【{name}】预计 {days_left} 天内用完，可提前提醒复购。")
++
++
++def list_home_products(conn, customer_id):
