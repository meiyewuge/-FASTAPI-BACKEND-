# 服务
APP_ENV=dev
APP_PORT=8000

# 数据库（默认 SQLite，零依赖即可运行；生产换 PostgreSQL）
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/meiye_v4
DATABASE_URL=sqlite:///./meiye_v4.db

# 多租户 / 鉴权
DEFAULT_TENANT=default
JWT_SECRET=change_me

# 视频生成 provider：mock（默认）| keling | jimeng | runway | volcano ...
# 接真实 provider 时，把对应 KEY 填好并改 VIDEO_PROVIDER
VIDEO_PROVIDER=mock
VIDEO_FALLBACK=true            # 真实 provider 失败时回退（最终回退 mock，保证不中断）
VIDEO_API_BASE=
VIDEO_API_KEY=
PROVIDER_TIMEOUT=120          # 单次任务最长等待秒数
POLL_INTERVAL=3               # 轮询间隔秒数

# 成本系统（mock 演示参数）
COST_PER_MOTHER=1.0
COST_PER_CLIP=0.1
