# 服务
APP_ENV=dev
APP_PORT=8000

# 数据库（默认 SQLite，零依赖即可运行；生产换 PostgreSQL）
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/meiye_v4
DATABASE_URL=sqlite:///./meiye_v4.db

# 多租户 / 鉴权
DEFAULT_TENANT=default
JWT_SECRET=change_me

# 视频生成 provider：mock（默认）| volcano_seedance | keling | jimeng | runway ...
VIDEO_PROVIDER=mock
VIDEO_FALLBACK=true            # 真实 provider 失败时回退（最终回退 mock，保证不中断）
PROVIDER_RETRIES=3           # 真实 provider 失败后重试次数（再回退 mock）
PROVIDER_TIMEOUT=120          # 单次任务最长等待秒数
POLL_INTERVAL=3               # 轮询间隔秒数

# —— 火山 Doubao Seedance 2.0 ——（接真实视频时填；密钥勿提交到仓库）
# VIDEO_PROVIDER=volcano_seedance
VIDEO_API_BASE=https://ark.cn-beijing.volces.com
VOLC_MODEL=doubao-seedance-2.0-260128

# 鉴权模式：bearer（默认，Ark /api/v3 用）| aksk（HMAC-SHA256 签名）
VOLC_AUTH_MODE=bearer
# bearer 模式：填 ARK API Key
VIDEO_API_KEY=
# aksk 模式：填 AccessKey / SecretKey
VOLC_AK=
VOLC_SK=
VOLC_REGION=cn-beijing
VOLC_SERVICE=ark

# 成本系统（mock 演示参数）
COST_PER_MOTHER=1.0
COST_PER_CLIP=0.1
