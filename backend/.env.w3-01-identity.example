# DSM W3-01 authoritative employee-identity chain — example config.
# Copy to `.env` and fill REAL values via a secret manager. NEVER commit real
# secrets, real openid, or real phone numbers. All identity config is read from
# this single Settings source (no second os.environ path).

# Master switch. Default OFF: identity routes are not mounted and legacy behavior
# is unchanged. ON requires the migrated schema + complete/independent config or
# the app fails closed at startup.
IDENTITY_I1_ENABLED=false

# WeChat mini-program credentials (code2session). Required when enabled.
# The secret is sent to api.weixin.qq.com over TLS (protocol requirement) but must
# never reach the frontend, logs, exceptions, the database, or Git.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TIMEOUT_SECONDS=5.0

# openid pseudonymization key — INDEPENDENT, >= 32 chars. Must NOT equal the WeChat
# secret, the adapter shared secret, or any daily-loop root key. Rotate per policy.
DM_OPENID_HMAC_KEY=

# Main-backend marker (must be true when identity is enabled) + the single DM_*
# shared secret the main backend is allowed to hold (independence check only; not
# used by the W3-01 login chain itself).
DM_MAIN_BACKEND=false
DM_ADAPTER_SHARED_SECRET=

# Login throttle + one-time-code replay window (defaults shown).
AUTH_LOGIN_RATE_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_MAX_ATTEMPTS=10
AUTH_CODE_REPLAY_WINDOW_SECONDS=300
