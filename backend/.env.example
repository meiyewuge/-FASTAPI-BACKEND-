# ═══════════════════════════════════════════════════════════════════════
# 美业无忧 FastAPI 后端 — 环境变量配置占位
# 真实值仅通过环境变量注入，不写死、不入库。
# ═══════════════════════════════════════════════════════════════════════

# ── 基础配置 ──────────────────────────────────────────────────────
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:8000
# 经营诊断 H5 跳转域名（webview-token 返回 URL 前缀）
H5_BASE_URL=https://wuyou.beautypeaceai.com
DATABASE_URL=sqlite:///./storecoach.db
ADMIN_KEY=dev_admin_key

# ── LLM 配置 ─────────────────────────────────────────────────────
LLM_PROVIDER=local
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── Coze 公共配置 ────────────────────────────────────────────────
COZE_API_BASE=https://api.coze.cn
COZE_API_TOKEN=                    # ← 必填（真实值经环境变量注入）
COZE_TIMEOUT=30                    # 单次请求超时（秒）

# ── Coze · chat（Bot Chat）───────────────────────────────────────
COZE_CHAT_ENABLED=false            # 灰度开关，默认 false 走模板
COZE_CHAT_BOT_ID=                  # ← 扣子 Bot ID

# ── Coze · private（Workflow）────────────────────────────────────
COZE_PRIVATE_ENABLED=false         # 灰度开关，默认 false 走模板
COZE_PRIVATE_WORKFLOW_ID=          # ← 扣子 Workflow ID

# ── Coze · content（Workflow）────────────────────────────────────
COZE_CONTENT_ENABLED=false         # 灰度开关，默认 false 走模板
COZE_CONTENT_WORKFLOW_ID=          # ← 扣子 Workflow ID
