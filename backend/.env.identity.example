# Stage I1 identity — deployment env TEMPLATE (keys only, NO real values).
#
# Do NOT rename to `.env` (compose/dotenv auto-load) until real values are written
# by the deployer into a root-only (chmod 600, root:root) file on the server.
# Never commit real secrets. This template lists ONLY key names + permission notes.
#
# I0 fact (from KOUZI_IDENTITY_STAGE_I0): staging AND production currently have
# NO WeChat keys and NO identity tables. Therefore, D3 preconditions:
#   1) run the reviewed identity migration (dialect-correct) FIRST;
#   2) set the keys below in a root-only env file;
#   3) only then set IDENTITY_I1_ENABLED=1 (the app fails closed if the schema
#      is not migrated).

# Master switch. Default OFF. When 1, identity/Facade routes mount and startup
# verifies (a) complete + independent WeChat/HMAC config and (b) the migrated
# identity schema at the exact machine version (dl_identity_schema_meta = i1-r1a),
# else the app REFUSES to start (no half-usable state).
IDENTITY_I1_ENABLED=0

# Marks this as the real main-backend process so the Daily Loop adapter's secret
# root isolation is actively enforced (Caller/Recovery/Vault roots -> fail closed).
DM_MAIN_BACKEND=1

# WeChat mini-program credentials (server-side code2session only). REQUIRED (non-
# empty) when identity is enabled.
# Correct handling promise: the code2session protocol DOES send WECHAT_APP_SECRET
# to WeChat as an HTTPS query parameter (unavoidable, to api.weixin.qq.com over
# TLS). Our guarantee is that the secret never enters the FRONTEND, our business
# LOGS, EXCEPTIONS, the DATABASE, or GIT — and it is read only from this env.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Independent HMAC key for openid pseudonymization (>=32 chars). REQUIRED in
# staging/prod when identity is enabled — the salted-sha256 fallback is for LOCAL
# DEV WITH IDENTITY DISABLED ONLY and is rejected at startup when enabled.
# MUST be an independent secret — never reuse WECHAT_APP_SECRET,
# DM_ADAPTER_SHARED_SECRET, DM_CALLER_SIGNING_KEY, or any Recovery/Vault root
# (startup rejects equality). Rotation: rotating this key re-pseudonymizes openids
# (existing rows keyed by the old value stop matching), so rotate only during a
# planned re-bind window.
DM_OPENID_HMAC_KEY=

# S2S root shared with the Daily Loop internal API (the ONLY DM_* secret the main
# backend may hold). Adapter stays OFF unless DM_DAILY_LOOP_ADAPTER_ENABLED=1.
DM_ADAPTER_SHARED_SECRET=

# R1c: the Facade → Adapter → Daily Loop Client chain reads ALL of its config from
# this single source (Settings/.env), never a second os.environ path. Feature flag
# OFF by default; base URL is NOT a secret. Set the flag to 1 only after the S2S
# shared secret is provisioned and the Daily Loop internal API is reachable.
DM_DAILY_LOOP_ADAPTER_ENABLED=0
DM_DAILY_LOOP_BASE_URL=http://127.0.0.1:18090

# NOTE: Caller / Platform-Recovery / Vault roots MUST NOT appear in the main
# backend env (enforced fail-closed by daily_loop_adapter because DM_MAIN_BACKEND=1).
