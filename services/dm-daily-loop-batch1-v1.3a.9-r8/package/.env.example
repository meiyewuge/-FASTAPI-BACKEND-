# DM Daily Loop — 业务环境变量示例
# 复制为 .env 并填入真实值, 禁止提交真实密钥到版本控制

# Vault主密钥 — AES-GCM派生用, 至少16字符, 禁止dev_前缀
DM_VAULT_MASTER_KEY=change_me_to_real_key_at_least_16_chars

# CallerContext签名密钥 — 至少16字符, 禁止dev_前缀
DM_CALLER_SIGNING_KEY=change_me_to_real_signing_key_at_least_16_chars

# 日频编排服务凭据 — 用于system身份
DM_SERVICE_PRINCIPAL_SECRET=change_me_to_real_service_secret
