# DM Daily Loop — PROD business env TEMPLATE (keys only, NO real values).
#
# This is a TEMPLATE. Do NOT rename to `daily-loop.prod.env` in a directory
# compose auto-loads until real values are written by the deployer into a
# root-only (chmod 600, root:root) file on the server. Never commit real secrets.
#
# This is the Daily Loop SERVICE env. The Daily Loop service mints CallerContext
# internally, so it holds DM_CALLER_SIGNING_KEY. The MAIN BACKEND process must NOT
# hold DM_CALLER_SIGNING_KEY / vault / recovery roots — it gets ONLY
# DM_ADAPTER_SHARED_SECRET (see the main-backend key-isolation guard).
#
# Break-glass PLATFORM RECOVERY roots (DM_PLATFORM_RECOVERY_SIGNING_KEY /
# DM_PLATFORM_RECOVERY_SECRET) are deliberately ABSENT here: recovery is an
# offline break-glass tool and its roots never enter the business service env.

# S2S root shared with the main-backend adapter (HMAC only). REQUIRED.
DM_ADAPTER_SHARED_SECRET=

# CallerContext signing root — minted INSIDE the Daily Loop service. REQUIRED here,
# FORBIDDEN in the main backend.
DM_CALLER_SIGNING_KEY=

# Vault master key for the keyring. REQUIRED by the Daily Loop service.
DM_VAULT_MASTER_KEY=

# Service principal secret for system-context minting. REQUIRED.
DM_SERVICE_PRINCIPAL_SECRET=

# Path to the Daily Loop auth DB inside the container (matches the mounted volume).
DM_DAILY_LOOP_AUTH_DB=/data/auth.db

# Adapter feature flag: keep OFF (unset or !=1) until the main backend is wired.
# DM_DAILY_LOOP_ADAPTER_ENABLED=0
