# ============================================================
# WUGE Search Router P0 — 环境变量配置模板
# 基于《WUGE Search Router P0 代码实现任务拆分 V0.1.1》
# ============================================================
# ⚠️ 本文件不含任何真实 API Key
# ⚠️ 仅作模板，使用时复制为 .env 并填入真实 Key（.env 已被 .gitignore 排除）
# ============================================================

# ---- 运行模式 ----
# SEARCH_ROUTER_DRY_RUN: dry_run=true 时强制所有 Provider 走 Mock，不调任何真实 API
# 默认 true（P0 Phase 1 强制 dry_run）
SEARCH_ROUTER_DRY_RUN=true

# ---- Provider 开关 ----
# PROVIDER_MOCK_ENABLED: Mock Provider 总开关，默认 true
PROVIDER_MOCK_ENABLED=true

# PROVIDER_BOCHA_ENABLED: 博查搜索（中文国内资讯主力），默认 false
PROVIDER_BOCHA_ENABLED=false

# PROVIDER_GLM_SEARCH_ENABLED: 智谱 GLM 搜索（免费源），默认 false
PROVIDER_GLM_SEARCH_ENABLED=false

# PROVIDER_TAVILY_ENABLED: Tavily 搜索（英文全球资讯主力），默认 false
PROVIDER_TAVILY_ENABLED=false

# ---- LLM 增强开关 ----
# GLM_ENHANCER_ENABLED: 独立控制 LLM 产业字段增强是否启用
# ⚠️ 三锁铁律：只有以下三者同时满足时才允许真实 GLM 增强：
#   1. SEARCH_ROUTER_DRY_RUN=false
#   2. PROVIDER_GLM_SEARCH_ENABLED=true
#   3. GLM_ENHANCER_ENABLED=true
# 缺一不可，否则强制走 Mock 增强
GLM_ENHANCER_ENABLED=false

# ---- 成本熔断阈值（¥，吴哥已确认，不可修改）----
# 单次任务成本上限
COST_LIMIT_SINGLE_TASK=2.0
# 单日成本上限
COST_LIMIT_DAILY=30.0
# 单月成本上限
COST_LIMIT_MONTHLY=300.0
# 单 Provider 日成本上限
COST_LIMIT_PROVIDER_DAILY=10.0
# 连续失败次数上限
PROVIDER_MAX_CONSECUTIVE_FAILURES=3

# ---- 搜索参数 ----
# 单任务最大搜索结果数
MAX_SEARCH_RESULTS=20
# 单任务最大候选卡数
MAX_CANDIDATE_CARDS=10

# ---- 日志 ----
# LOG_DESENSITIZE: 日志脱敏开关，true 时强制对 Key/URL 脱敏
LOG_DESENSITIZE=true
# LOG_LEVEL: 日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---- API Key 占位（P0 Phase 1 不使用，仅占位）----
# ⚠️ 以下 Key 在 P0 Phase 1 (dry_run) 阶段不读取、不使用
# ⚠️ Phase 2/3 时由吴哥通过安全渠道注入 ECS 环境变量
# BOCHA_API_KEY=
# ZHIPU_API_KEY=
# TAVILY_API_KEY=
